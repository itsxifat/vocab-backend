# ── Database ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vocab

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Admin Auth (JWT) ───────────────────────────────────────────────────────────
# Generate with: npm run gen-key
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_strong_password
JWT_SECRET=generate_a_64_char_random_string_here

# ── App API Key (React Native app uses this) ───────────────────────────────────
# Generate with: npm run gen-key
APP_API_KEY=generate_a_32_char_random_string_here

# ── CORS whitelist (comma-separated origins) ───────────────────────────────────
# Leave empty to allow all (dev only). Set in production!
CORS_ORIGINS=https://yourdomain.com,http://localhost:8081

# ── Dictionary Vendors (optional API keys) ────────────────────────────────────
# Merriam-Webster: https://www.dictionaryapi.com/ (free tier available)
MERRIAM_WEBSTER_KEY=

# Wordnik: https://developer.wordnik.com/ (free tier)
WORDNIK_KEY=

# ── Bengali Translation ────────────────────────────────────────────────────────
# Google Cloud Translate: https://cloud.google.com/translate (paid, ~$20/1M chars)
# Leave empty to use free MyMemory API instead (5,000 chars/day free)
GOOGLE_TRANSLATE_KEY=

# MyMemory free-tier email (raises limit to 50,000 chars/day, still free)
MYMEMORY_EMAIL=

# ── Word List ──────────────────────────────────────────────────────────────────
# Path to a plain-text word list (one word per line) for auto-fetch
# Defaults to ./scripts/words.txt
WORDLIST_PATH=./scripts/words.txt

# Auto-fetch concurrency (simultaneous API requests)
FETCH_CONCURRENCY=5
