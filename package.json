    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.1",
    "express-slow-down": "^2.0.3",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "uuid": "^10.0.0",
    "multer": "^1.4.5-lts.1",
    "sax": "^1.4.1",
    "unbzip2-stream": "^1.4.3"
