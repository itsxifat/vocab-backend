{
  "name": "vocab-backend",
  "version": "2.0.0",
  "description": "Vocab dictionary backend — Express + MongoDB + Multi-vendor fetch",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
